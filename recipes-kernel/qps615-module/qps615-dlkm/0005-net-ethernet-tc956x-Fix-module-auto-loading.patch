From 7e937fd13e6f69e534b2d1b437606806afd849a1 Mon Sep 17 00:00:00 2001
From: Mohd Ayaan Anwar <mohd.anwar@oss.qualcomm.com>
Date: Mon, 16 Mar 2026 16:39:40 +0530
Subject: [PATCH 5/5] net: ethernet: tc956x: Fix module auto-loading

Add a module table entry so that the QPS615 driver is automatically
loaded without the need to rely on a systemd service file or
KERNEL_MODULE_AUTOLOAD entry in its Yocto recipe.

Upstream-Status: Submitted [https://github.com/TC956X/TC9564_Host_Driver/pull/5]
Signed-off-by: Mohd Ayaan Anwar <mohd.anwar@oss.qualcomm.com>
---
 drivers/net/ethernet/toshiba/tc956x/tc956x_pci.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/net/ethernet/toshiba/tc956x/tc956x_pci.c b/drivers/net/ethernet/toshiba/tc956x/tc956x_pci.c
index 1140971..9574186 100644
--- a/drivers/net/ethernet/toshiba/tc956x/tc956x_pci.c
+++ b/drivers/net/ethernet/toshiba/tc956x/tc956x_pci.c
@@ -4715,6 +4715,8 @@ static const struct pci_device_id tc956xmac_id_table[] = {
 	{}
 };
 
+MODULE_DEVICE_TABLE(pci, tc956xmac_id_table);
+
 static SIMPLE_DEV_PM_OPS(tc956xmac_pm_ops, tc956x_pcie_suspend, tc956x_pcie_resume);
 
 static struct pci_driver tc956xmac_pci_driver = {
-- 
2.34.1

